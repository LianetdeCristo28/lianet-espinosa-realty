# ── Base de Datos (requerido: al menos uno) ──────────────────
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Seguridad (requerido en producción) ──────────────────────
SESSION_SECRET=genera-un-string-aleatorio-largo-aqui

# ── Admin (requerido para crear el primer usuario) ───────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu-contraseña-segura

# ── Servidor ─────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Integraciones (opcionales) ───────────────────────────────
N8N_WEBHOOK_URL=https://tu-n8n.ejemplo.com/webhook/xxxxx

# ── Analytics (opcionales) ───────────────────────────────────
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
FB_PIXEL_ID=1234567890
